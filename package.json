{
  "name": "crmb-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter='./apps/**' --parallel dev",
    "build": "pnpm --filter='./apps/**' build",
    "test": "pnpm --filter='./apps/**' test",
    "lint": "pnpm --filter='./apps/**' lint",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "devDependencies": {
    "husky": "^8.0.0",
    "lint-staged": "^13.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "prettier --write"
    ]
  }
}